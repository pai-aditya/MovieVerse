# Copy to backend/.env and adjust as needed for local development.
# In Kubernetes these are supplied via ConfigMaps (non-secret) and Secrets.

# URLs the BROWSER uses (CORS + OAuth + frontend bundle).
CLIENT_URL=http://localhost:5173
SERVER_URL=http://localhost:5555
PORT=5555

# --- PostgreSQL ---
# Either set DATABASE_URL, or the individual DB_* vars below.
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/movieverse
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=movieverse

# --- Session ---
SESSION_SECRET=change-me-in-production
# Set to "true" only when served over HTTPS (enables Secure + SameSite=None cookies).
COOKIE_SECURE=false

# --- Optional Google OAuth (leave blank for username/password auth only) ---
# Authorized redirect URI must be ${SERVER_URL}/auth/google/callback
CLIENT_ID=
CLIENT_SECRET=
