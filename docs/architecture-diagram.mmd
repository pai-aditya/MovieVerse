    %% ── Flows ─────────────────────────────────────────────────────────────

    %% User traffic
    Browser -- "HTTP :8080
(kubectl port-forward)" --> kubectl
    kubectl --> EdgeProxy
    EdgeProxy -- "proxy_pass :80" --> FEDeploy
    EdgeProxy -- "proxy_pass :5555" --> BEDeploy

    %% Browser calls external APIs directly
    Browser -. "TMDB movie data
(fetch from browser)" .-> TMDB
    BEDeploy -. "Google OAuth callback
(if CLIENT_ID set)" .-> GoogleOAuth

    %% Backend → DB
    InitC -- "nc -z :5432" --> PGSts
    BEDeploy -- "pg pool :5432" --> PGSts
    MigJob -- "schema migration" --> PGSts
    BackupCJ -- "pg_dump" --> PGSts
    BackupCJ --> BackupPVC

    %% Config injection
    ConfigMap --> BEDeploy
    Secrets --> BEDeploy
    Secrets --> PGSts
    Secrets --> BackupCJ

    %% Storage provisioning
    LPP -- "provisions" --> PGPVC
    LPP -- "provisions" --> BackupPVC
    PGPVC --> PGSts

    %% Metrics
    Prom -- "pod-SD scrape
/metrics :5555" --> BEDeploy
    Prom -- "cAdvisor
(kubelet API)" --> CP
    Graf -- "query" --> Prom
    Graf -- "query" --> Loki

    %% Logs
    Promtail -- "push logs
:3100" --> Loki

    %% CI: push → Jenkins → ghcr
    GitHub -- "push (any branch)
webhook / 2-min scan" --> Jenkins
    Jenkins -- "docker build + push
:&lt;slug&gt;-&lt;sha&gt;" --> GHCR
    Jenkins -. "hard refresh (best-effort)" .-> ArgoCD

    %% CD: ArgoCD app-of-apps + per-branch ApplicationSet
    GitHub -- "SCM generator
polls branch heads" --> AppSet
    ArgoCD -- "owns / reconciles" --> AppSet
    AppSet -- "one Application per branch
ns/image/db/port injected" --> NS_PREVIEW
    ArgoCD -- "platform app-of-apps
(prune + selfHeal)" --> NS_MON
    ArgoCD -- "platform app-of-apps" --> NS_LOG
    ArgoCD -- "platform app-of-apps" --> NS_VAULT
    ArgoCD -- "shared data-plane" --> PGSts

    %% Preview env wiring
    GHCR -- "image pull" --> PvFE
    GHCR -- "image pull" --> PvBE
    PvEdge --> PvFE
    PvEdge --> PvBE
    PvBE -- "cross-ns :5432
(ExternalName → shared)" --> PGSts
    PvJob -- "createdb + migrate" --> PGSts
    Browser -- "HTTP NodePort
&lt;node-ip&gt;:30000+hash" --> PvEdge

    %% Image loading (manual bootstrap only — superseded by ghcr in CI/CD)
    Colima -. "docker save | ctr import
(manual bootstrap)" .-> W1
    Colima -. "docker save | ctr import" .-> W2
    Colima -. "docker save | ctr import" .-> DBNode

    %% Node placement annotations
    FEDeploy -. "scheduled on
mv-w1 / mv-w2
(topologySpread)" .-> W1
    FEDeploy -. "scheduled on
mv-w1 / mv-w2" .-> W2
    BEDeploy -. "scheduled on
mv-w1 / mv-w2
(topologySpread + antiAffinity)" .-> W1
    BEDeploy -. "scheduled on
mv-w1 / mv-w2" .-> W2
    PGSts -. "pinned to mv-db
(toleration + nodeAffinity)" .-> DBNode

