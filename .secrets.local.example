# Copy this to '.secrets.local' (gitignored) and fill in your values.
# setup.sh sources it automatically; anything you export in the shell still wins.

# GitHub classic PAT with write:packages (required)
GHCR_PAT=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitHub username / ghcr owner (optional, defaults to pai-aditya)
GHCR_USER=pai-aditya

# Jenkins admin password (optional, defaults to admin)
# ADMIN_PASSWORD=admin
