# OS / editor
.DS_Store

# Local secrets / env
.env
*.local

# etcd snapshots written by kubeadm/etcd-backup.sh
/backups/

# image tarballs created by kubeadm/load-images.sh
*.tar

# never commit a real CA bundle (kept in ~/.movieverse-ca, outside the repo)
*.pem

# Jenkins deployer kubeconfig minted by jenkins-up.sh (contains a live SA token)
cicd/jenkins/.jenkins-deployer.kubeconfig
